# Notion OAuth (public integration — create one at notion.so/profile/integrations)
NOTION_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
NOTION_CLIENT_SECRET=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_REDIRECT_URI=http://localhost:8000/auth/notion/callback

# Notion legacy shared key (only needed for the /v1/article legacy routes)
# NOTION_API_KEY=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# DynamoDB
DYNAMODB_TABLE_NAME=notohub-articles
AWS_REGION=ap-southeast-1

# S3
S3_BUCKET_NAME=notohub-content
# Region the bucket actually lives in (independent of AWS_REGION) — required
# for correctly signed presigned URLs. Check with:
#   aws s3api get-bucket-location --bucket <name>   (null result means us-east-1)
S3_BUCKET_REGION=us-east-1

# CORS — set to your frontend origin in production
ALLOWED_ORIGIN=https://app.notohub.com

# Public API URL — embedded in generated article HTML for the "More from" fetch
PUBLIC_API_URL=https://api.notohub.com

# Cognito — copy these from your frontend .env.local
COGNITO_USER_POOL_ID=ap-southeast-1_xxxxxxxxx
COGNITO_APP_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
# COGNITO_REGION defaults to AWS_REGION if not set
# COGNITO_REGION=ap-southeast-1
